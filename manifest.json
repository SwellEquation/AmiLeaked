{
  "manifest_version": 3,
  "name": "AmiLeaked Skeleton",
  "version": "0.1.0",
  "description": "Base Chrome extension skeleton for the AmiLeaked project.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AmiLeaked"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
