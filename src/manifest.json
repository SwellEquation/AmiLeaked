{
  "{{chrome}}.manifest_version": 3,
  "name": "AmiLeaked",
  "version": "1.0.0",
  "description": "Network leak detector that runs in the background while you browse",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "{{chrome}}.action": {
    "default_popup": "src/popup.html"
  },
  "{{chrome}}.permissions": ["storage", "notifications", "offscreen"],
  "host_permissions": [
    "https://api.ipify.org/*",
    "https://checkip.amazonaws.com/*",
    "https://api6.ipify.org/*",
    "https://dns.google/*"
  ],
  "background": {
    "{{chrome}}.service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "{{chrome}}.web_accessible_resources": [
    {
      "resources": ["src/offscreen.html", "src/offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

