{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "name": "AmiLeaked",
  "version": "0.1.0",
  "description": "Network leak detector that runs in the background while you browse",
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "{{chrome}}.action": {
    "default_popup": "src/popup.html"
  },
  "{{firefox}}.browser_action": {
    "default_popup": "src/popup.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.ipify.org/*",
    "https://checkip.amazonaws.com/*",
    "https://api6.ipify.org/*",
    "https://cloudflare-dns.com/*"
  ],
  "background": {
    "{{chrome}}.service_worker": "src/background.js",
    "{{firefox}}.scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}

